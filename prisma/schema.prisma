generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model WatchSymbol {
  id            String    @id @default(cuid())
  symbol        String    @unique
  displayName   String?
  regionOverride String?
  autoName      String?
  autoRegion    String?
  autoCurrency  String?
  metaUpdatedAt DateTime?
  enabled       Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  members       WatchlistMember[]

  @@index([enabled, sortOrder])
}

model Watchlist {
  id        String          @id @default(cuid())
  name      String          @unique
  sortOrder Int             @default(0)
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  members   WatchlistMember[]

  @@index([sortOrder])
}

model WatchlistMember {
  id           String     @id @default(cuid())
  watchlistId   String
  watchSymbolId String
  enabled      Boolean    @default(true)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  watchlist    Watchlist  @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  watchSymbol  WatchSymbol @relation(fields: [watchSymbolId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, watchSymbolId])
  @@index([watchlistId, enabled, sortOrder])
  @@index([watchSymbolId])
}

model DailyPrice {
  id        String   @id @default(cuid())
  symbol    String
  tradeDate DateTime
  close     Decimal
  adjClose  Decimal
  currency  String
  source    String   @default("yahoo")
  fetchedAt DateTime @default(now())

  @@index([symbol])
  @@unique([symbol, tradeDate])
}

enum JobStatus {
  success
  partial
  failed
}

model UpdateJobLog {
  id             String    @id @default(cuid())
  jobDate        DateTime
  startedAt      DateTime
  endedAt        DateTime
  status         JobStatus
  totalSymbols   Int
  successSymbols Int
  failedSymbols  Int
  message        String?
  createdAt      DateTime  @default(now())
}
